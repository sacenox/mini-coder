{
  "name": "mini-coder-next",
  "version": "0.6.0",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "bin": {
    "mc": "bin/mc.ts"
  },
  "scripts": {
    "dev": "bun run bin/mc.ts",
    "check": "bun run lint && bun run typecheck",
    "lint": "bun run biome check --write .",
    "typecheck": "bun run tsc -p tsconfig.json --noEmit",
    "format": "bun run prettier --write *.md && bun run biome format --write . && bun run biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@cel-tui/components": "^0.8.2",
    "@cel-tui/core": "^0.8.2",
    "@mariozechner/pi-ai": "^0.70.2",
    "diff": "^9.0.0",
    "simple-git": "^3.36.0",
    "yaml": "^2.8.3"
  }
}
