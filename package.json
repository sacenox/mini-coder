{
  "name": "mini-coder",
  "version": "0.5.0",
  "description": "A small, fast CLI coding agent",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "mc": "bin/mc.ts"
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "bun run src/index.ts",
    "check": "biome check src",
    "check:fix": "biome check --write src",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@cel-tui/components": "^0.4.0",
    "@cel-tui/core": "^0.4.0",
    "@mariozechner/pi-ai": "^0.65.0",
    "diff": "^8.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
