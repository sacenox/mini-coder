{
  "name": "mini-coder",
  "version": "0.5.0",
  "description": "A small, fast CLI coding agent",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "mc": "dist/mc.js"
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "bun run src/index.ts",
    "format": "prettier --write --log-level warn .",
    "check": "bun run prettier -c . && bun run typecheck && bun run lint",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "bun test"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
